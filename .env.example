# This block controls backend logging verbosity.
# It takes: one of DEBUG, INFO, WARNING, ERROR, CRITICAL.
# It gives: the default logger level used by structured logging.
RRA_LOG_LEVEL=INFO

# This block configures Groq inference access.
# It takes: your Groq API key.
# It gives: authenticated access to the LPU-backed inference endpoint.
GROQ_API_KEY=your_groq_api_key_here

# This block configures the Kraken CLI execution layer.
# It takes: the Kraken CLI binary path and optional profile name.
# It gives: the execution node enough context to call the CLI safely.
KRAKEN_CLI_PATH=kraken
KRAKEN_PROFILE=default

# This block configures LangGraph checkpoint persistence.
# It takes: a local SQLite database path for checkpoint storage.
# It gives: durable graph state and resumable execution.
LANGGRAPH_CHECKPOINT_DB=backend/data/langgraph_checkpoints.db

# This block configures ERC-8004 registry access.
# It takes: an RPC URL and the deployed registry contract address.
# It gives: on-chain trust and registration lookup capability.
ERC8004_RPC_URL=https://your-rpc-endpoint-here
ERC8004_REGISTRY_ADDRESS=0xYourRegistryContractAddressHere

# This block configures TEE attestation via direct endpoint mode.
# It takes: the provider endpoint and required access metadata.
# It gives: a remote attestation path for enclave verification.
PHALA_CLOUD_ATTESTATION_ENDPOINT=https://your-phala-attestation-endpoint
PHALA_CLOUD_API_TOKEN=your_phala_api_token_here
PHALA_CLOUD_PROJECT_ID=your_phala_project_id_here
PHALA_CLOUD_CLUSTER_ID=your_phala_cluster_id_here
PHALA_CLOUD_APP_ID=your_phala_app_id_here

# This block configures TEE attestation via command mode.
# It takes: a provider CLI command that returns JSON on stdout.
# It gives: an alternative local enrollment/attestation path.
PHALA_CLOUD_ENROLL_COMMAND=

# This block is optional and can be used by the shell script for timeout tuning.
# It takes: the timeout in seconds for TEE enrollment or attestation requests.
# It gives: bounded script execution for attestation calls.
TEE_TIMEOUT_SECONDS=15
TEE_PROVIDER=phala
TEE_VERBOSE=0
